{
  "$schema": "http://json.schemastore.org/package.json",
  "name": "fractal-explorer",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "format": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "dev": "bun ./index.html",
    "build": "bun build --target=browser --sourcemap --outdir=dist ./index.html"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260309.1",
    "@webgpu/types": "latest",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3"
  }
}
